# AI模型配置（任选其一或多个）
AI_PROVIDER=deepseek  # 可选: deepseek, ollama


# DeepSeek配置
DEEPSEEK_API_KEY=sk-xxx
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# Ollama本地配置
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:3b

# Web搜索API配置
SERPER_API_KEY=1b8f636e401253d8c9c7c27dd386d9d287f9f087
# 备选: GOOGLE_SEARCH_API_KEY 和 GOOGLE_SEARCH_ENGINE_ID
# 备选: BING_SEARCH_API_KEY

# 飞书机器人Webhook
FEISHU_WEBHOOK_URL=xxx

# 数据存储路径
EXCEL_DIR=./data
DATABASE_URL=sqlite:///./data/intelligence.db

# 定时任务配置
SCHEDULE_TIMES=09:00,18:00,11:28  # 多个时间用逗号分隔
TIMEZONE=Asia/Shanghai

# 前端访问地址（用于企业微信消息链接）
FRONTEND_URL=http://localhost:3000
